# VectorView config — copy to .env and fill in your values

# Qdrant connection
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Port VectorView serves on
VECTORVIEW_PORT=7433

# Max points pulled per collection
# PCA is O(n × dim) — keep this reasonable for large collections
VECTORVIEW_MAX_POINTS=2000
